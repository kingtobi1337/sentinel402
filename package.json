{
  "name": "sentinel402",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous pay-per-evidence procurement on Hedera x402",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "npm run typecheck && npm test && npm run build",
    "e2e:mock": "tsx scripts/e2e-mock.ts",
    "e2e:testnet": "tsx scripts/e2e-testnet.ts",
    "testnet:bootstrap": "tsx scripts/bootstrap-testnet.ts",
    "secret:scan": "node scripts/secret-scan.mjs"
  },
  "dependencies": {
    "@hiero-ledger/sdk": "2.86.2",
    "@hono/node-server": "2.0.11",
    "@x402/core": "2.19.0",
    "@x402/fetch": "2.19.0",
    "@x402/hedera": "2.19.0",
    "@x402/hono": "2.19.0",
    "dotenv": "16.6.1",
    "hono": "4.12.31"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "overrides": {
    "@grpc/grpc-js": "1.14.4",
    "@hiero-ledger/proto": {
      "protobufjs": "8.7.1"
    },
    "@hiero-ledger/sdk": {
      ".": "2.86.2",
      "protobufjs": "8.7.1"
    },
    "ethers": {
      "ws": "8.21.1"
    }
  }
}
